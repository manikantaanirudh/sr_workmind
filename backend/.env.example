APP_ENV=dev
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
# OAuth callbacks use this base URL — must match Salesforce / DocuSign app settings.
PUBLIC_BACKEND_URL=http://127.0.0.1:8000
OAUTH_REDIRECT_BASE_URL=http://127.0.0.1:8000
TOKEN_STORAGE_DIR=backend/logs
SNOWFLAKE_USE_SQL_API=false
# When sql_exec_tool returns "Error parsing response", run SQL via PAT SQL API instead.
SNOWFLAKE_MCP_SQL_API_FALLBACK=true

# LLM Provider: ollama | groq | huggingface | gemini
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_URL=http://localhost:11434/api/generate
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Snowflake MCP Server connection
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# Programmatic Access Token (PAT) for MCP Server authentication
# Generate this in Snowflake: Admin > Users > Your User > Generate PAT
SNOWFLAKE_PAT=

# MCP Server configuration (must match the MCP Server object created in Snowflake)
MCP_SERVER_NAME=srworkmind_mcp_server
MCP_TOOL_NAME=sql_exec_tool

# Legacy: warehouse/role only used as LLM context hints
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# Leave empty unless your PAT is tied to a specific role (do not use ACCOUNTADMIN unless granted).
SNOWFLAKE_ROLE=

# Optional schema hints to improve LLM SQL generation
SNOWFLAKE_TABLE_HINTS=customers(customer_name, revenue, region); orders(order_id, customer_name, order_date, sales_amount)

SALESFORCE_INSTANCE_URL=
SALESFORCE_CONSUMER_KEY=
SALESFORCE_MCP_SERVER_URL=https://api.salesforce.com/platform/mcp/v1/platform/sobject-all
SALESFORCE_OBJECT_HINTS=Account(Id, Name, Industry, Type, Phone, Website, BillingCity, BillingState); Contact(Id, FirstName, LastName, Email, Phone, AccountId, Title, Department); Opportunity(Id, Name, StageName, Amount, CloseDate, AccountId, Probability); Case(Id, Subject, Status, Priority, ContactId, AccountId, Description); Lead(Id, FirstName, LastName, Company, Status, Email, Phone, Industry); Task(Id, Subject, Status, Priority, WhoId, WhatId, ActivityDate)

DOCUSIGN_CLIENT_ID=
DOCUSIGN_CLIENT_SECRET=
DOCUSIGN_OAUTH_BASE_URL=https://account-d.docusign.com
DOCUSIGN_MCP_SERVER_URL=https://mcp-d.docusign.com/mcp
DOCUSIGN_MCP_RESOURCE=https://mcp-d.docusign.com/mcp
DOCUSIGN_SCOPES=signature extended agreement_object_model_read aow_manage
DOCUSIGN_REQUIRE_HUMAN_APPROVAL=true

# Register these exact callback URLs in your OAuth apps (local dev):
# Salesforce Connected App → http://127.0.0.1:8000/oauth/salesforce/callback
# DocuSign App → http://127.0.0.1:8000/oauth/docusign/callback
# Render production:
# https://sr-workmind-backend.onrender.com/oauth/salesforce/callback
# https://sr-workmind-backend.onrender.com/oauth/docusign/callback
